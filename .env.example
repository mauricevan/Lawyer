# Database
DATABASE_URL=postgresql+asyncpg://lawyer:lawyer_dev@localhost:5432/lawyer

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=eurlex_chunks

# LLM — openrouter (default) or anthropic
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it:free
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Embeddings — set USE_LOCAL_EMBEDDINGS=true to avoid OpenAI costs in dev
USE_LOCAL_EMBEDDINGS=true
OPENAI_API_KEY=your_openai_api_key_here

# JWT
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
ENABLE_LIVE_FALLBACK=true
LIVE_FALLBACK_TIMEOUT_SECONDS=6.0

# Cache
ENABLE_REDIS_CACHE=true
REDIS_URL=redis://localhost:6379/0
RETRIEVAL_CACHE_TTL_SECONDS=86400
FALLBACK_SCORE_THRESHOLD=0.18
RRF_K=60
ENABLE_CELERY_INGEST=true
FEATURE_FLAG_LIVE_FALLBACK=true
FEATURE_FLAG_HYBRID_RRF=true
FEATURE_FLAG_AUTO_UPGRADE=true
FEATURE_FLAG_AUDIT_LOGGING=true

EVAL_RECALL_AT_5_MIN=0.80
EVAL_MRR_MIN=0.70
RERANK_TOP_K=8
RETRIEVAL_BUDGET_SECONDS=8.0
INGEST_QUEUE_MAX_PENDING=200
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=100
ADMIN_API_KEY=
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin_password
JWT_AUTH_REQUIRED=false
AUDIT_RETENTION_DAYS=90
QUERY_LOG_RETENTION_DAYS=90
FEEDBACK_RETENTION_DAYS=365
CONVERSATION_RETENTION_DAYS=180

# EUR-Lex bulk dump (fase 4+) - keep empty in template
EU_LOGIN_EMAIL=
EU_LOGIN_PASSWORD=
