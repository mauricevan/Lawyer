# Database
DATABASE_URL=postgresql+asyncpg://lawyer:lawyer_dev@localhost:5432/lawyer

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=eurlex_chunks

# LLM — openrouter (default) or anthropic
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it:free
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Embeddings — set USE_LOCAL_EMBEDDINGS=true to avoid OpenAI costs in dev
USE_LOCAL_EMBEDDINGS=true
OPENAI_API_KEY=your_openai_api_key_here

# JWT
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# EUR-Lex bulk dump (fase 4+)
EU_LOGIN_EMAIL=
EU_LOGIN_PASSWORD=
